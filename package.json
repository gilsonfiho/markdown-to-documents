{
  "name": "markdown-to-docx",
  "version": "1.0.0",
  "description": "Markdown to DOCX converter with Google authentication",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,html,md,mdx,json,css,scss}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,html,md,mdx,json,css,scss}\"",
    "lint": "eslint -c .eslintrc.cjs --ext .js,.jsx,.ts,.tsx . --max-warnings=0",
    "lint:fix": "eslint -c .eslintrc.cjs --ext .js,.jsx,.ts,.tsx . --fix"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.0",
    "docx": "^8.5.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.575.0",
    "mermaid": "^11.12.3",
    "next": "^16.1.6",
    "next-auth": "^4.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^4.12.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0"
  }
}
