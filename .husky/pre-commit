#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Executando verificações pre-commit..."
echo ""

# 1. ESLint + Prettier
echo "📝 Executando ESLint..."
npm run lint:fix

if [ $? -ne 0 ]; then
  echo "❌ ESLint falhou"
  exit 1
fi

echo "✅ ESLint passou"
echo ""

# 2. Prettier
echo "🎨 Formatando com Prettier..."
npm run format

if [ $? -ne 0 ]; then
  echo "❌ Prettier falhou"
  exit 1
fi

echo "✅ Prettier passou"
echo ""

# 3. Testes
echo "🧪 Executando testes..."
npm run test -- --passWithNoTests

# shellcheck disable=SC2181
if [ $? -ne 0 ]; then
  echo "❌ Testes falharam"
  exit 1
fi

echo "✅ Testes passaram"
echo ""

# 4. Build TypeScript
echo "🔨 Verificando build..."
npm run build

# shellcheck disable=SC2181
if [ $? -ne 0 ]; then
  echo "❌ Build falhou"
  exit 1
fi

echo "✅ Build passou"
echo ""

echo "✅ Todas as verificações passaram! Commit permitido."

